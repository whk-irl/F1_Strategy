# =============================================================================
# .env.example — copy to .env and fill in your values.
#
# Variables are prefixed PITWALL_ and loaded by pydantic-settings.
# Never commit .env (it is in .gitignore); commit only .env.example.
# =============================================================================

# ---------------------------------------------------------------------------
# Storage backend
# Set to "minio" for local docker-compose dev, "s3" for AWS cloud.
# ---------------------------------------------------------------------------
PITWALL_STORAGE_BACKEND=s3

# ---------------------------------------------------------------------------
# MinIO (local dev — only used when PITWALL_STORAGE_BACKEND=minio)
# ---------------------------------------------------------------------------
PITWALL_MINIO_ENDPOINT=localhost:9000
PITWALL_MINIO_ACCESS_KEY=minioadmin
PITWALL_MINIO_SECRET_KEY=minioadmin
PITWALL_MINIO_BUCKET=pitwall-ai
PITWALL_MINIO_USE_SSL=false

# ---------------------------------------------------------------------------
# AWS S3 (cloud prod — only used when PITWALL_STORAGE_BACKEND=s3)
#
# Credentials are NOT set here; they come from:
#   - IRSA (IAM role bound to the Kubernetes service account) on EKS
#   - EC2 instance profile when running on a VM
#   - AWS_PROFILE / AWS_ACCESS_KEY_ID for local testing against real S3
#
# The bucket must be created by Terraform before first use.
# ---------------------------------------------------------------------------
PITWALL_AWS_REGION=us-east-1
PITWALL_AWS_S3_BUCKET=pitwall-ai-prod

# ---------------------------------------------------------------------------
# FastF1 HTTP cache
# ---------------------------------------------------------------------------
PITWALL_FASTF1_CACHE_PATH=.fastf1_cache

# ---------------------------------------------------------------------------
# Live race data provider
#   signalr — free F1.com live timing (formula1.com/en/timing/f1-live)  [default]
#   openf1  — OpenF1 REST API (requires PITWALL_OPENF1_API_KEY during live sessions)
#   auto    — SignalR when connected, else OpenF1
# ---------------------------------------------------------------------------
PITWALL_LIVE_PROVIDER=signalr

# Streamlit Cloud: set to true in app secrets for live-race-only deployment
# (no replay tab, auto-refresh, F1.com timing feed only).
# PITWALL_LIVE_ONLY=true

# Optional — only needed for F1TV-only extras, NOT for the free timing page.
# PITWALL_F1_SUBSCRIPTION_TOKEN=

# OpenF1 API key (fallback provider)
# PITWALL_OPENF1_API_KEY=

# ---------------------------------------------------------------------------
# MLflow tracking server
# ---------------------------------------------------------------------------
PITWALL_MLFLOW_TRACKING_URI=http://localhost:5000
PITWALL_MLFLOW_EXPERIMENT_NAME=pitwall-ingestion

# ---------------------------------------------------------------------------
# (Cloud) AWS account / ECR — used by Makefile cloud targets and GitHub Actions
# Set these in your shell or CI environment; not read by the Python app.
# ---------------------------------------------------------------------------
# AWS_ACCOUNT_ID=123456789012
# AWS_REGION=us-east-1
# ECR_REGISTRY=$(AWS_ACCOUNT_ID).dkr.ecr.$(AWS_REGION).amazonaws.com
# ARGO_SERVER=<argo-server-host>:<port>
# EKS_CLUSTER_NAME=pitwall-prod
